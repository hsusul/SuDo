generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum WorkspaceRole {
  owner
  admin
  member
}

enum WorkspaceInvitationStatus {
  pending
  accepted
  revoked
  expired
}

enum DemoMode {
  shared_editable
  read_only
  cloned
}

enum IssueStatusType {
  backlog
  todo
  in_progress
  done
}

enum IssuePriority {
  low
  medium
  high
  urgent
}

model User {
  id                           String                @id @default(cuid())
  clerkUserId                  String                @unique
  email                        String                @unique
  name                         String?
  imageUrl                     String?
  createdAt                    DateTime              @default(now())
  updatedAt                    DateTime              @updatedAt
  memberships                  WorkspaceMember[]
  createdProjects              Project[]             @relation("ProjectCreator")
  createdIssues                Issue[]               @relation("IssueCreator")
  assignedIssues               Issue[]               @relation("IssueAssignee")
  comments                     Comment[]
  activityLogs                 ActivityLog[]         @relation("ActivityActor")
  createdWorkspaces            Workspace[]           @relation("WorkspaceCreator")
  demoResets                   DemoReset[]
  sentWorkspaceInvitations     WorkspaceInvitation[] @relation("WorkspaceInvitationInviter")
  acceptedWorkspaceInvitations WorkspaceInvitation[] @relation("WorkspaceInvitationAcceptor")
  createdSavedViews            SavedView[]           @relation("SavedViewCreator")

  @@index([clerkUserId])
}

model Workspace {
  id              String                @id @default(cuid())
  name            String
  slug            String                @unique
  description     String?
  createdById     String
  isDemo          Boolean               @default(false)
  demoMode        DemoMode?
  lastDemoResetAt DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  archivedAt      DateTime?
  createdBy       User                  @relation("WorkspaceCreator", fields: [createdById], references: [id], onDelete: Restrict)
  members         WorkspaceMember[]
  projects        Project[]
  statuses        IssueStatus[]
  issues          Issue[]
  labels          Label[]
  comments        Comment[]
  activityLogs    ActivityLog[]
  demoResets      DemoReset[]
  invitations     WorkspaceInvitation[]
  savedViews      SavedView[]

  @@index([createdById])
  @@index([isDemo])
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(member)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
  @@index([workspaceId])
}

model WorkspaceInvitation {
  id           String                    @id @default(cuid())
  workspaceId  String
  email        String
  role         WorkspaceRole             @default(member)
  status       WorkspaceInvitationStatus @default(pending)
  tokenHash    String                    @unique
  invitedById  String
  acceptedById String?
  expiresAt    DateTime
  acceptedAt   DateTime?
  revokedAt    DateTime?
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  workspace    Workspace                 @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy    User                      @relation("WorkspaceInvitationInviter", fields: [invitedById], references: [id], onDelete: Restrict)
  acceptedBy   User?                     @relation("WorkspaceInvitationAcceptor", fields: [acceptedById], references: [id], onDelete: SetNull)

  @@index([workspaceId, status])
  @@index([email, status])
  @@index([invitedById])
  @@index([acceptedById])
}

model Project {
  id           String        @id @default(cuid())
  workspaceId  String
  name         String
  key          String
  description  String?
  color        String?
  icon         String?
  sortOrder    Int           @default(0)
  createdById  String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  archivedAt   DateTime?
  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy    User          @relation("ProjectCreator", fields: [createdById], references: [id], onDelete: Restrict)
  issues       Issue[]
  activityLogs ActivityLog[]
  savedViews   SavedView[]

  @@unique([workspaceId, key])
  @@index([workspaceId])
  @@index([archivedAt])
}

model IssueStatus {
  id          String          @id @default(cuid())
  workspaceId String
  name        String
  type        IssueStatusType
  color       String?
  sortOrder   Int             @default(0)
  isDefault   Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  workspace   Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  issues      Issue[]

  @@unique([workspaceId, type])
  @@unique([workspaceId, name])
  @@index([workspaceId, sortOrder])
}

model Issue {
  id           String        @id @default(cuid())
  workspaceId  String
  projectId    String
  statusId     String
  creatorId    String
  assigneeId   String?
  issueNumber  Int
  issueKey     String
  title        String
  description  String?
  priority     IssuePriority @default(medium)
  sortOrder    Decimal?      @db.Decimal(20, 10)
  dueDate      DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  completedAt  DateTime?
  archivedAt   DateTime?
  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status       IssueStatus   @relation(fields: [statusId], references: [id], onDelete: Restrict)
  creator      User          @relation("IssueCreator", fields: [creatorId], references: [id], onDelete: Restrict)
  assignee     User?         @relation("IssueAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  labels       IssueLabel[]
  comments     Comment[]
  activityLogs ActivityLog[]

  @@unique([workspaceId, issueKey])
  @@unique([projectId, issueNumber])
  @@index([workspaceId, updatedAt])
  @@index([workspaceId, statusId])
  @@index([workspaceId, priority])
  @@index([workspaceId, projectId])
  @@index([assigneeId])
}

model Label {
  id          String       @id @default(cuid())
  workspaceId String
  name        String
  slug        String
  color       String
  description String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  issues      IssueLabel[]

  @@unique([workspaceId, slug])
  @@index([workspaceId])
}

model IssueLabel {
  id        String   @id @default(cuid())
  issueId   String
  labelId   String
  createdAt DateTime @default(now())
  issue     Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  label     Label    @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@unique([issueId, labelId])
  @@index([labelId])
}

model Comment {
  id          String    @id @default(cuid())
  workspaceId String
  issueId     String
  authorId    String
  body        String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  issue       Issue     @relation(fields: [issueId], references: [id], onDelete: Cascade)
  author      User      @relation(fields: [authorId], references: [id], onDelete: Restrict)

  @@index([issueId, createdAt])
  @@index([workspaceId])
  @@index([authorId])
}

model ActivityLog {
  id          String    @id @default(cuid())
  workspaceId String
  issueId     String?
  projectId   String?
  actorId     String?
  action      String
  metadata    Json?
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  issue       Issue?    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  project     Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  actor       User?     @relation("ActivityActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([issueId, createdAt])
  @@index([actorId])
}

model SavedView {
  id          String    @id @default(cuid())
  workspaceId String
  projectId   String
  creatorId   String?
  name        String
  filters     Json
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator     User?     @relation("SavedViewCreator", fields: [creatorId], references: [id], onDelete: SetNull)

  @@unique([workspaceId, name])
  @@index([workspaceId, updatedAt])
  @@index([projectId])
  @@index([creatorId])
}

model DemoReset {
  id          String    @id @default(cuid())
  workspaceId String
  resetById   String?
  reason      String?
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  resetBy     User?     @relation(fields: [resetById], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([resetById])
}
