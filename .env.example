# App
# Local: http://localhost:3000
# Production: https://your-vercel-domain.vercel.app or your custom domain.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Clerk
# Create these values in the Clerk dashboard.
# Both the publishable key and secret key are required for protected /app routes.
# Use production Clerk keys in Vercel; do not reuse local development secrets unless intentional.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/app/issues"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/app/issues"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/app/issues"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/app/issues"

# Database
# Use local Postgres for development and Neon Postgres for the default production setup.
# For Neon production, DATABASE_URL should usually be the pooled/runtime connection string.
# Runtime database access and local user sync require this value.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"
# Optional but recommended for hosted databases that provide pooled URLs.
# For Neon production, DIRECT_DATABASE_URL should be the direct/non-pooled connection string.
# Prisma CLI migration commands prefer this value when present.
DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Demo seed
# Optional local seed helper. Must match an already-synced Clerk user email in the User table.
# Do not set this in Vercel unless you intentionally want command-line demo seeding there.
DEMO_SEED_USER_EMAIL=""
